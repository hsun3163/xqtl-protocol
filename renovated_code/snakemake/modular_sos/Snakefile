# ============================================================
# rule all — full pipeline targets
# ============================================================
rule all:
    """Run the complete xQTL pipeline (Modular SoS) for all configured themes."""
    default_target: True
    input:
        [get_molecular_phenotype_bed_by_theme(theme) for theme in THEMES]
        if config.get("start_from", "") == "fastq" else [],
        get_genotype_chrom_list(),
        [get_projected_pca_rds(theme) for theme in THEMES],
        [get_hidden_factors_by_theme(theme) for theme in THEMES],
        expand(
            "{cwd}/association_scan/{theme}/TensorQTL/.done_cis",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/finemapping/{theme}/susie_twas/.done_susie_twas",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/finemapping/{theme}/susie_twas_plots/.done_plots",
            cwd=CWD, theme=THEMES,
        ),


# ============================================================
# rule xqtl_core — complete Modular SoS pipeline without plots
# ============================================================
rule xqtl_core:
    """Run Modular SoS through association and SuSiE/TWAS fine-mapping, excluding plots."""
    input:
        [get_molecular_phenotype_bed_by_theme(theme) for theme in THEMES]
        if config.get("start_from", "") == "fastq" else [],
        get_genotype_chrom_list(),
        [get_projected_pca_rds(theme) for theme in THEMES],
        [get_hidden_factors_by_theme(theme) for theme in THEMES],
        expand(
            "{cwd}/association_scan/{theme}/TensorQTL/.done_cis",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/finemapping/{theme}/susie_twas/.done_susie_twas",
            cwd=CWD, theme=THEMES,
        ),


# ── Convenience stage targets ─────────────────────────────────────────────────
rule phenotype_preprocessing:
    input:
        expand(
            "{cwd}/{theme}/phenotype_preprocessing/{theme}.bed.gz",
            cwd=CWD, theme=THEMES,
        ) if config.get("start_from", "") == "raw_phenotype" else [],
        expand(
            "{cwd}/{theme}/phenotype_preprocessing/{theme}.bed.imputed.bed.gz",
            cwd=CWD, theme=THEMES,
        ) if (
            config.get("start_from", "") == "raw_phenotype"
            and config["phenotype_preprocessing"].get("run_imputation", False)
        ) else [],

rule phenotype_calling:
    input:
        [get_molecular_phenotype_bed_by_theme(theme) for theme in THEMES],

rule genotype_preprocessing:
    input:
        get_genotype_chrom_list(),

rule sample_qc_pca:
    input:
        [get_projected_pca_rds(theme) for theme in THEMES],

rule covariate_prep:
    input:
        [get_hidden_factors_by_theme(theme) for theme in THEMES],

rule association_testing:
    input:
        expand(
            "{cwd}/association_scan/{theme}/TensorQTL/.done_cis",
            cwd=CWD, theme=THEMES,
        ),

rule finemapping:
    input:
        expand(
            "{cwd}/finemapping/{theme}/susie_twas/.done_susie_twas",
            cwd=CWD, theme=THEMES,
        ),
