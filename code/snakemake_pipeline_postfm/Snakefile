# ============================================================
# xQTL Protocol — Post-Finemapping Snakemake Pipeline
# ============================================================
# Downstream analyses starting from univariate SuSiE finemapping
# results produced by the main xqtl-protocol pipeline.
#
# Stages (in order):
#   1. Results export & visualization
#        Convert RDS → TSV, extract top credible-set loci,
#        PIP landscape plots, UpSetR credible-set overlap plots.
#
#   2. TWAS and colocalization  [requires config.gwas.enabled: true]
#        TWAS gene-trait association (cTWAS), SuSiE-ENLOC Bayesian
#        colocalization, ColocBoost multi-trait colocalization.
#
#   3. Enrichment analyses
#        EOO annotation enrichment, KEGG pathway enrichment (GSEA),
#        stratified LD score regression (S-LDSC).
#
# Usage:
#   snakemake --configfile config.yaml --cores <N> [--use-singularity]
#
# The pipeline expects the finemapping results in:
#   {finemapping_dir}/{theme}/susie_twas/   (*.rds files)
# which is the default output layout of rule susie_twas in the
# main pipeline (code/snakemake_pipeline/Snakefile).
# ============================================================

configfile: "config.yaml"

# ── Validate required configuration keys ────────────────────────────────────
_required = ["cwd", "pipeline_dir", "finemapping_dir", "themes",
             "containers", "postprocessing", "resources"]
for _k in _required:
    if _k not in config:
        raise ValueError(f"Required config key '{_k}' is missing from config.yaml")

# ── Convenience variables ────────────────────────────────────────────────────
CWD          = config["cwd"]
PIPELINE     = config["pipeline_dir"]
THEMES       = [t["name"] for t in config["themes"]]
FM_DIR       = config["finemapping_dir"]
GWAS_ENABLED = config.get("gwas", {}).get("enabled", False)
ENRICH_ANNOT = config.get("enrichment", {}).get("annotation", {}).get("enabled", False)
ENRICH_PATH  = config.get("enrichment", {}).get("pathway",     {}).get("enabled", False)
ENRICH_SLDSC = config.get("enrichment", {}).get("sldsc",       {}).get("enabled", False)

SLDSC_ANNOTS = (
    config["enrichment"]["sldsc"].get("annotation_names", [])
    if ENRICH_SLDSC else []
)

# ── Dry-run flags ────────────────────────────────────────────────────────────
DRY_RUN_SOS    = "-n" if config.get("dry_run", False) else ""
DRY_RUN_NATIVE = "--dry-run" if config.get("dry_run", False) else ""


# ── Helper: resolve per-theme finemapping directory ──────────────────────────
def _get_finemapping_dir(wc):
    """Return the susie_twas output directory for a given theme wildcard."""
    theme_cfg = next(t for t in config["themes"] if t["name"] == wc.theme)
    # Allow per-theme override; default: {finemapping_dir}/{theme}/susie_twas
    override = theme_cfg.get("finemapping_subdir", "")
    if override:
        return override
    return f"{FM_DIR}/{wc.theme}/susie_twas"


def _get_theme_param(wc, key):
    """Return a required per-theme config value (raises if missing)."""
    theme_cfg = next(t for t in config["themes"] if t["name"] == wc.theme)
    val = theme_cfg.get(key, "")
    if not val:
        raise ValueError(
            f"Theme '{wc.theme}': required key '{key}' is missing or empty."
        )
    return val


def _get_theme_gwas_param(wc, key):
    """
    Return a GWAS-specific per-theme parameter.
    Falls back to the global config["gwas"][key] if not set per-theme.
    """
    theme_cfg = next(t for t in config["themes"] if t["name"] == wc.theme)
    # Per-theme override takes priority
    per_theme = theme_cfg.get("gwas", {}).get(key, "")
    if per_theme:
        return per_theme
    # Global fallback
    val = config.get("gwas", {}).get(key, "")
    if not val:
        raise ValueError(
            f"Theme '{wc.theme}': GWAS key '{key}' is missing in both the "
            "per-theme config and the global config.gwas block."
        )
    return val


# ── Include rule modules ─────────────────────────────────────────────────────
include: "rules/01_postprocessing.smk"
include: "rules/02_twas_coloc.smk"
include: "rules/03_enrichment.smk"


# ============================================================
# rule all — full post-finemapping pipeline
# ============================================================
rule all:
    """Run all enabled post-finemapping analyses for every theme."""
    input:
        # ── 1. Postprocessing (always) ───────────────────────────────────────
        expand(
            "{cwd}/postprocessing/{theme}/susie_tsv/.done_tsv",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/postprocessing/{theme}/top_loci/.done_top_loci",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/postprocessing/{theme}/pip_landscape/.done_pip_landscape",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/postprocessing/{theme}/upsetr_plots/.done_upsetr",
            cwd=CWD, theme=THEMES,
        ),

        # ── 2. TWAS + colocalization (only when gwas.enabled: true) ─────────
        expand(
            "{cwd}/twas/{theme}/.done_twas",
            cwd=CWD, theme=THEMES,
        ) if GWAS_ENABLED else [],
        expand(
            "{cwd}/colocalization/{theme}/susie_coloc/.done_coloc",
            cwd=CWD, theme=THEMES,
        ) if GWAS_ENABLED else [],
        expand(
            "{cwd}/colocalization/{theme}/colocboost/.done_colocboost",
            cwd=CWD, theme=THEMES,
        ) if GWAS_ENABLED else [],

        # ── 3a. Annotation enrichment (only when enrichment.annotation.enabled) ──
        expand(
            "{cwd}/enrichment/{theme}/annotation/.done_annotation_enrichment",
            cwd=CWD, theme=THEMES,
        ) if ENRICH_ANNOT else [],

        # ── 3b. Pathway enrichment (only when enrichment.pathway.enabled) ───
        expand(
            "{cwd}/enrichment/{theme}/pathway/.done_pathway_enrichment",
            cwd=CWD, theme=THEMES,
        ) if ENRICH_PATH else [],

        # ── 3c. S-LDSC (only when enrichment.sldsc.enabled; GWAS required) ─
        expand(
            "{cwd}/enrichment/sldsc/{annotation_name}/meta/.done_sldsc_meta",
            cwd=CWD, annotation_name=SLDSC_ANNOTS,
        ) if ENRICH_SLDSC else [],


# ============================================================
# Convenience stage targets
# ============================================================

rule postprocessing:
    """Run only the results export and visualization stage."""
    input:
        expand(
            "{cwd}/postprocessing/{theme}/susie_tsv/.done_tsv",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/postprocessing/{theme}/top_loci/.done_top_loci",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/postprocessing/{theme}/pip_landscape/.done_pip_landscape",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/postprocessing/{theme}/upsetr_plots/.done_upsetr",
            cwd=CWD, theme=THEMES,
        ),


rule twas_coloc:
    """Run TWAS and colocalization analyses (requires gwas.enabled: true)."""
    input:
        expand(
            "{cwd}/twas/{theme}/.done_twas",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/colocalization/{theme}/susie_coloc/.done_coloc",
            cwd=CWD, theme=THEMES,
        ),
        expand(
            "{cwd}/colocalization/{theme}/colocboost/.done_colocboost",
            cwd=CWD, theme=THEMES,
        ),


rule enrichment:
    """Run all enrichment analyses that are enabled in the config."""
    input:
        expand(
            "{cwd}/enrichment/{theme}/annotation/.done_annotation_enrichment",
            cwd=CWD, theme=THEMES,
        ) if ENRICH_ANNOT else [],
        expand(
            "{cwd}/enrichment/{theme}/pathway/.done_pathway_enrichment",
            cwd=CWD, theme=THEMES,
        ) if ENRICH_PATH else [],
        expand(
            "{cwd}/enrichment/sldsc/{annotation_name}/meta/.done_sldsc_meta",
            cwd=CWD, annotation_name=SLDSC_ANNOTS,
        ) if ENRICH_SLDSC else [],
